---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SakePairingCalculator from '../../components/SakePairingCalculator.astro';
import SeasonalCalendar from '../../components/SeasonalCalendar.astro';
---

<BaseLayout title="工具箱">
  <div class="tools-header">
    <h1>🧰 寿司工具箱</h1>
    <p>精选实用工具，让寿司与清酒选择更简单</p>
  </div>
  
  <!-- 清酒配对计算器 -->
  <div class="tool-section">
    <SakePairingCalculator />
  </div>
  
  <!-- 旬味日历 -->
  <div class="tool-section">
    <SeasonalCalendar />
  </div>
  
  <div class="tool-note">
    <p>📌 配对规则基于专业品鉴师建议，数据每月更新</p>
  </div>
</BaseLayout>

<style>
  .tools-header {
    text-align: center;
    margin-bottom: 2rem;
  }
  
  .tools-header h1 {
    font-size: 2rem;
  }
  
  .tools-header p {
    color: var(--text-secondary);
    margin-top: 0.5rem;
  }
  
  .tool-section {
    margin-bottom: 3rem;
  }
  
  .tool-note {
    text-align: center;
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border-light);
    color: var(--indigo-pale);
    font-size: 0.85rem;
  }
</style>