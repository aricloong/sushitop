---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getFishList } from '../../lib/notion';

const fishList = await getFishList();
---

<BaseLayout title="寿司百科">
  <h1>📖 寿司百科</h1>
  <div class="grid">
    {fishList.map(fish => (
      <div class="card">
        <h3>{fish.name}</h3>
        <p>{fish.japaneseName}</p>
        <p>最佳季节: {fish.bestMonths.join(', ')}</p>
        <p>🍽️ {fish.eatingMethod} | 🍶 {fish.sakePairing}</p>
      </div>
    ))}
  </div>
</BaseLayout>

<style>
  .card {
    background: var(--rice-white-dark);
    border-radius: 8px;
    padding: 1rem;
  }
  .card h3 { margin-bottom: 0.25rem; }
  .card p { margin: 0.25rem 0; font-size: 0.9rem; }
</style>